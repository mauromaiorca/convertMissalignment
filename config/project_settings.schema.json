{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MissAlignment v8 resolved project settings",
  "type": "object",
  "required": [
    "project",
    "paths",
    "geometry",
    "conversion",
    "datasets",
    "missalignment",
    "cluster",
    "reconstruction",
    "provenance"
  ],
  "properties": {
    "project": {
      "type": "object",
      "required": ["basename", "schema_version", "layout_version"],
      "properties": {
        "basename": {"type": "string", "minLength": 1},
        "schema_version": {"type": "integer", "minimum": 1},
        "layout_version": {"const": 8}
      },
      "additionalProperties": true
    },
    "paths": {
      "type": "object",
      "required": ["data_root", "output_dir"],
      "properties": {
        "data_root": {"type": "string", "minLength": 1},
        "output_dir": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "input": {"type": "object", "additionalProperties": true},
    "geometry": {
      "type": "object",
      "required": [
        "raw_shape_xyz",
        "raw_pixel_size_A",
        "aligned_shape_xyz",
        "aligned_pixel_size_A",
        "target_volume_shape_xyz",
        "target_pixel_size_A",
        "tilt_axis_angle_deg"
      ],
      "properties": {
        "raw_shape_xyz": {"$ref": "#/$defs/shape3"},
        "aligned_shape_xyz": {"$ref": "#/$defs/shape3"},
        "target_volume_shape_xyz": {"$ref": "#/$defs/shape3"},
        "raw_pixel_size_A": {"type": "number", "exclusiveMinimum": 0},
        "aligned_pixel_size_A": {"type": "number", "exclusiveMinimum": 0},
        "target_pixel_size_A": {"type": "number", "exclusiveMinimum": 0},
        "tilt_axis_angle_deg": {"type": "number"}
      },
      "additionalProperties": true
    },
    "conversion": {
      "type": "object",
      "required": ["initial_conditions", "condition_modes"],
      "properties": {
        "initial_conditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {"type": "string"}
        },
        "condition_modes": {"type": "object", "additionalProperties": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "datasets": {
      "type": "object",
      "required": ["native_id", "native_pixel_size_A", "selected_id"],
      "properties": {
        "native_id": {"$ref": "#/$defs/datasetId"},
        "selected_id": {"$ref": "#/$defs/datasetId"},
        "native_pixel_size_A": {"type": "number", "exclusiveMinimum": 0}
      },
      "additionalProperties": true
    },
    "multiresolution": {"type": "object", "additionalProperties": true},
    "ctf": {"type": "object", "additionalProperties": true},
    "missalignment": {
      "type": "object",
      "required": ["refinement_mode", "result_backend"],
      "additionalProperties": true
    },
    "cluster": {"type": "object", "additionalProperties": true},
    "reconstruction": {"type": "object", "additionalProperties": true},
    "provenance": {
      "type": "object",
      "required": ["resolved"],
      "properties": {"resolved": {"const": true}},
      "additionalProperties": true
    }
  },
  "$defs": {
    "shape3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"type": "integer", "minimum": 1}
    },
    "datasetId": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+)?Apx$"
    }
  },
  "additionalProperties": true
}
